{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "firebase:emulator:storage": "firebase emulators:start --only storage",
    "migrations:generate": "npm run typeorm -- migration:generate -d src/datasource.ts src/db/migrations/migration",
    "migrations:run": "npm run typeorm -- migration:run -d src/datasource.ts",
    "migrations:rollback": "npm run typeorm -- migration:revert -d src/datasource.ts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e-emulator": "firebase emulators:exec --only auth 'npm run test:e2e'",
    "typeorm": "typeorm-ts-node-commonjs"
  },
  "dependencies": {
    "@nestjs/common": "11.1.11",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.0.1",
    "@nestjs/platform-express": "11.1.11",
    "@nestjs/swagger": "11.2.5",
    "@nestjs/typeorm": "11.0.0",
    "class-validator": "0.14.3",
    "firebase-admin": "13.6.0",
    "googleapis": "170.1.0",
    "http-status-codes": "2.3.0",
    "mysql": "2.18.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "sqlite3": "5.1.7",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@faker-js/faker": "9.9.0",
    "@nestjs/cli": "11.0.14",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.1",
    "@types/express": "5.0.0",
    "@types/jest": "30.0.0",
    "@types/multer": "2.0.0",
    "@types/node": "22.10.7",
    "@types/supertest": "6.0.2",
    "dotenv": "17.3.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "firebase": "12.7.0",
    "firebase-tools": "15.2.1",
    "globals": "16.0.0",
    "jest": "30.0.0",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      ".+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
