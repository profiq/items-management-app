{
  "name": "profiq-reference-app",
  "version": "0.0.2",
  "description": "The goal of this project is to build a reference project & architecture for all our future project. Meaning we want to have everything in this project correct. And it will be inspiration for all the future projects.",
  "scripts": {
    "changelog:stdout": "conventional-changelog --stdout -i /dev/null -p angular",
    "changelog:update": "conventional-changelog -p angular",
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint . --fix",
    "fix:prettier": "prettier --write .",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "prepare": "husky",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@gitlab.com/profiq/all/infra/profiq-reference-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://gitlab.com/profiq/all/infra/profiq-reference-app/issues"
  },
  "homepage": "https://gitlab.com/profiq/all/infra/profiq-reference-app#readme",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "conventional-changelog": "7.2.0",
    "conventional-changelog-angular": "8.3.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.0.0",
    "typescript-eslint": "8.52.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "eslint": "9.39.2",
    "eslint-plugin-react": "7.37.5",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.7.4"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
